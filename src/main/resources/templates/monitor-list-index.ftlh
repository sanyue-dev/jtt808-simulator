<!DOCTYPE html>
<html lang="en">
<head>
<#include "inc/resource.ftlh">
    <title>иЎЊзЁ‹д»»еЉЎ</title>
</head>
<body>
<div class="container">
<#include "inc/sidebar.ftlh">
    <div class="content datasheet">
        <h2>иЎЊзЁ‹д»»еЉЎ</h2>
        <hr />
        <div id="route-table"></div>
        <ul class="pagination"></ul>
    </div>
</div>
</body>
<#include "inc/footer.ftlh">
<script type="text/javascript">
    $(document).ready(function()
    {
        setCurrentMenu('list-monitor');
        $('#route-table').paginate({
            url: '/monitor/list/json',
            fields: [
                {
                    name: 'routeName',
                    title: 'зєїи·ЇеђЌз§°',
                    align: 'left',
                },
                {
                    name : 'routeMileages',
                    title : 'зєїи·Їй‡ЊзЁ‹',
                    align : 'right',
                    formatter : function(i, v, r)
                    {
                        return parseInt(v / 1000) + ' km';
                    }
                },
                {
                    name: 'vehicleNumber',
                    title: 'иЅ¦з‰ЊеЏ·',
                    align: 'center',
                },
                {
                    name: 'simNumber',
                    title: 'SIMеЌЎеЏ·',
                    align: 'center',
                },
                {
                    name: 'deviceSn',
                    title: 'з»€з«ЇID',
                    align: 'center',
                },
                {
                    name : 'startTime',
                    title : 'еђЇеЉЁж—¶й—ґ',
                    align : 'center',
                    formatter : function(i, v, r)
                    {
                        return new Date(v).format('yyyy-MM-dd hh:mm:ss');
                    }
                },
                {
                    name : 'longitude',
                    title : 'з»Џеє¦',
                    align : 'right',
                    formatter : function(i, v, r)
                    {
                        return v ? String(v).replace(/^(\d+\.\d{6})\d+$/gi, '$1') : '--';
                    }
                },
                {
                    name : 'latitude',
                    title : 'зє¬еє¦',
                    align : 'right',
                    formatter : function(i, v, r)
                    {
                        return v ? String(v).replace(/^(\d+\.\d{6})\d+$/gi, '$1') : '--';
                    }
                },
                {
                    name: 'id',
                    title: 'ж“ЌдЅњ',
                    align: 'center',
                    width : '160px',
                    formatter: function (i, v, r)
                    {
                        var html = '';
                        html += '<a href="/monitor/view?id=' + v + '" target="_blank" class="btn btn-sm btn-blue">иЇ¦жѓ…</a>';
                        return html;
                    }
                }
            ]
        });
    });
</script>
</html>
