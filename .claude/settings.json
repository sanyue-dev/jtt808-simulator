{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mvn compile*)",
      "Bash(mvn test-compile*)",
      "Bash(mvn test*)",
      "Bash(mvn verify*)",
      "Bash(./mvnw*)",
      "Bash(./gradlew*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/java-verify.sh"
          }
        ]
      }
    ]
  }
}